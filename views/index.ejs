<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Início | Planner AI</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/sidebar') %>

    <main class="main-content">
        <h1>Olá! 👋</h1>
        <p style="opacity: 0.6; margin-bottom: 40px;">Aqui estão seus projetos mais recentes:</p>

        <div class="notion-grid">
            <% notebooks.slice(0, 2).forEach(nb => { %>
                <a href="/notebook/<%= nb.id %>" class="notion-card" style="border-top: 5px solid <%= nb.color %>">
                    <strong><%= nb.name %></strong>
                </a>
            <% }) %>
        </div>

        <a href="/cadernos" style="display: inline-block; margin-top: 30px; font-weight: 600; color: var(--notion-blue); text-decoration: none;">
            Ver todos os projetos →
        </a>
    </main>
</body>
</html>
