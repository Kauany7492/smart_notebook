<!DOCTYPE html>
<html lang="pt-br" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= notebook.name %> | Planner AI</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <script>
        document.documentElement.setAttribute('data-theme', localStorage.getItem('notion-theme') || 'light');
    </script>

    <%- include('partials/sidebar') %>

    <main class="main-content">
        <header style="margin-bottom: 40px;">
            <h1 style="border-left: 8px solid <%= notebook.color %>; padding-left: 15px; margin-bottom: 5px;">
                <%= notebook.name %>
            </h1>
            <small style="opacity: 0.5;">Criado em <%= new Date(notebook.created_at).toLocaleDateString('pt-BR') %></small>
        </header>
        
        <div class="callout">
            <span>💡</span>
            <div>Use o microfone para ditar ou capture o áudio de uma aba do navegador para transcrever reuniões.</div>
        </div>

        <section class="input-area">
            <textarea id="quickNote" class="notion-editor" placeholder="Escreva um rascunho ou pontos principais..."></textarea>
            
            <div style="display: flex; gap: 10px; margin-bottom: 12px; align-items: center; flex-wrap: wrap;">
                <button onclick="toggleMic()" class="sidebar-item" id="micBtn" style="border: 1px solid var(--notion-border); width: auto;">
                    🎤 Ouvir Microfone
                </button>
                <button onclick="startTabAudio()" class="sidebar-item" style="border: 1px solid var(--notion-border); width: auto;">
                    🌐 Ouvir Aba
                </button>
                <div id="statusIcon" style="display: none; align-items: center; color: var(--notion-blue); font-size: 13px; font-weight: 600;">
                    <span class="pulse"></span> Gravando...
                </div>
            </div>

            <textarea id="transcription" class="notion-editor" style="font-size: 14px; opacity: 0.8; min-height: 120px;" placeholder="A transcrição do áudio aparecerá aqui..."></textarea>
            
            <button onclick="processWithAI()" id="btnProcess">✨ Gerar Plano de Ação</button>
        </section>

        <hr style="margin: 50px 0; border: 0; border-top: 1px solid var(--notion-border);">

        <div id="notes-container">
            <% notes.forEach(note => { %>
                <div class="notion-card" style="margin-bottom: 25px; position: relative; width: 100%;">
                    <button onclick="deleteNote('<%= note.id %>')" style="position: absolute; top: 15px; right: 15px; background: none; border: none; cursor: pointer; opacity: 0.3;">🗑️</button>
                    <div class="note-render">
                        <%- note.content %>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>

    <script>
        let recognition;
        let isListening = false;

        function toggleMic() {
            if (isListening) { recognition.stop(); return; }
            if (!('webkitSpeechRecognition' in window)) return alert("Navegador não suportado.");

            recognition = new webkitSpeechRecognition();
            recognition.lang = 'pt-BR';
            recognition.continuous = true;
            recognition.interimResults = true;

            recognition.onstart = () => {
                isListening = true;
                document.getElementById('statusIcon').style.display = 'flex';
                document.getElementById('micBtn').innerHTML = "⏹️ Parar";
            };

            recognition.onresult = (event) => {
                let text = '';
                for (let i = event.resultIndex; i < event.results.length; ++i) {
                    if (event.results[i].isFinal) text += event.results[i][0].transcript;
                }
                document.getElementById('transcription').value += text + ' ';
            };

            recognition.onend = () => {
                isListening = false;
                document.getElementById('statusIcon').style.display = 'none';
                document.getElementById('micBtn').innerHTML = "🎤 Ouvir Microfone";
            };
            recognition.start();
        }

        async function startTabAudio() {
            try {
                const stream = await navigator.mediaDevices.getDisplayMedia({ video: true, audio: true });
                alert("Captura iniciada. O áudio da aba será processado pelo microfone do sistema.");
                if(!isListening) toggleMic();
            } catch (err) { console.error(err); }
        }

        async function processWithAI() {
            const btn = document.getElementById('btnProcess');
            const transcription = document.getElementById('transcription').value;
            const quickNote = document.getElementById('quickNote').value;
            
            if(!transcription && !quickNote) return alert("Adicione conteúdo para a IA!");

            btn.innerText = "⏳ Criando Plano...";
            btn.disabled = true;

            const res = await fetch('/notebooks/<%= notebook.id %>/process', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ transcription, quickNote })
            });

            if (res.ok) window.location.reload();
            else { alert("Erro no servidor."); btn.innerText = "✨ Gerar Plano de Ação"; btn.disabled = false; }
        }

        async function deleteNote(id) {
            if(confirm("Excluir nota?")) {
                await fetch(`/delete-note/${id}`, { method: 'DELETE' });
                window.location.reload();
            }
        }
    </script>
</body>
</html>
