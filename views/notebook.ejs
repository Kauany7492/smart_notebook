<!DOCTYPE html>
<html lang="pt-br" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= notebook.name %> | Meu Notion AI</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-title">Workspace</div>
        <a href="/" class="sidebar-item">🏠 Início</a>
        
        <div style="margin-top: 20px;" class="sidebar-title">Meus Cadernos</div>
        <div class="sidebar-list">
            <% notebooks.forEach(nb => { %>
                <a href="/notebook/<%= nb.id %>" class="sidebar-item <%= nb.id == notebook.id ? 'active' : '' %>">
                    <span style="color: <%= nb.color %>">●</span> <%= nb.name %>
                </a>
            <% }) %>
        </div>

        <button onclick="toggleDarkMode()" class="sidebar-item" id="theme-toggle" style="margin-top: auto;">
            🌙 Modo Escuro
        </button>
    </aside>

    <main class="main-content">
        <header>
            <h1 style="border-left: 8px solid <%= notebook.color %>; padding-left: 16px;">
                <%= notebook.name %>
            </h1>
            <p style="opacity: 0.6; font-size: 14px;">Criado em: <%= new Date(notebook.created_at).toLocaleDateString('pt-BR') %></p>
        </header>

        <section class="callout">
            <div style="font-size: 24px;">📝</div>
            <div>
                <strong>Dica:</strong> Digite suas notas rápidas e cole a transcrição do áudio abaixo. O Gemini transformará tudo em um Plano de Ação estilo Notion.
            </div>
        </section>

        <div style="margin-top: 30px;">
            <textarea id="quickNote" class="notion-editor" placeholder="Digite aqui suas ideias ou rascunhos..."></textarea>
            <textarea id="transcription" class="notion-editor" style="font-size: 14px; opacity: 0.7;" placeholder="Cole a transcrição do áudio aqui..."></textarea>
            
            <button onclick="processWithAI()" class="btn-primary" id="btnProcess">
                ✨ Gerar Plano de Ação com IA
            </button>
        </div>

        <hr style="margin: 40px 0; border: 0
