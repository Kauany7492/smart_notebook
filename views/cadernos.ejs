<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meus Cadernos | Planner AI</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/sidebar') %>

    <main class="main-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;">
            <h1>📂 Todos os Projetos</h1>
            <button onclick="openModal()" class="btn-primary" style="border-radius: 50%; width: 45px; height: 45px; font-size: 24px; padding: 0;">+</button>
        </div>

        <div style="margin-bottom: 30px;">
            <input type="text" id="searchBar" onkeyup="filterNotebooks()" placeholder="Buscar caderno por nome..." class="notion-editor" style="border-radius: 8px; padding-left: 15px;">
        </div>

        <div class="notion-grid" id="notebooksGrid">
            <% notebooks.forEach(nb => { %>
                <a href="/notebook/<%= nb.id %>" class="notion-card notebook-item" data-name="<%= nb.name.toLowerCase() %>" style="border-top: 5px solid <%= nb.color %>">
                    <strong style="font-size: 18px;"><%= nb.name %></strong>
                    <p style="font-size: 12px; opacity: 0.5; margin-top: 15px;">Criado em: <%= new Date(nb.created_at).toLocaleDateString('pt-BR') %></p>
                </a>
            <% }) %>
        </div>
    </main>

    <div id="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:1000; align-items:center; justify-content:center; backdrop-filter: blur(4px);">
        <div class="notion-card" style="width: 350px; background: var(--notion-bg); padding: 30px;">
            <h3 style="margin-top: 0;">Novo Caderno</h3>
            <form action="/notebooks/create" method="POST">
                <label style="font-size: 12px; opacity: 0.6;">NOME DO PROJETO</label>
                <input type="text" name="name" class="notion-editor" required style="margin-bottom: 20px;">
                
                <label style="font-size: 12px; opacity: 0.6;">COR DE DESTAQUE</label>
                <input type="color" name="color" value="#2eaadc" style="width: 100%; height: 40px; border: none; background: none; cursor: pointer; margin-bottom: 25px;">
                
                <button type="submit" class="btn-primary" style="width: 100%; background: var(--notion-blue);">Criar Projeto</button>
                <button type="button" onclick="closeModal()" style="background:none; border:none; color:var(--notion-text); width:100%; margin-top:15px; cursor:pointer; opacity: 0.5;">Cancelar</button>
            </form>
        </div>
    </div>

    <script>
        function openModal() { document.getElementById('modal').style.display = 'flex'; }
        function closeModal() { document.getElementById('modal').style.display = 'none'; }

        function filterNotebooks() {
            const input = document.getElementById('searchBar').value.toLowerCase();
            const items = document.getElementsByClassName('notebook-item');
            
            Array.from(items).forEach(item => {
                const name = item.getAttribute('data-name');
                item.style.display = name.includes(input) ? "block" : "none";
            });
        }
    </script>
</body>
</html>
